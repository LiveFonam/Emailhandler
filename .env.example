

# Anthropic (used by Evil research agents src/llm.py, inherited)
ANTHROPIC_API_KEY=
CLAUDE_BUDGET_USD=

# Optional fallbacks (Evil's router uses these if Claude is unavailable)
GROQ_API_KEY=
GEMINI_API_KEY=

# Google Cloud (for Gmail API + Custom Search + Places)
# Create a project at https://console.cloud.google.com/
# Enable: Gmail API, Custom Search JSON API, Places API
# Create OAuth 2.0 client ID of type "Desktop app"
# Download the JSON and save it as data/credentials.json
GOOGLE_CLOUD_PROJECT=

# Google Programmable Search Engine (https://programmablesearchengine.google.com/)
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=

# Gmail account rotation (1 primary + 1-2 secondary, all your OWN accounts)
# The triage account (inherited friend's Gmail) is configured separately in app
# Do NOT use these for personal-inbox reads; use them for outreach sends only.
GMAIL_OUTREACH_ACCOUNT_1=you.personal@gmail.com
GMAIL_OUTREACH_ACCOUNT_2=you.secondary@gmail.com
GMAIL_OUTREACH_ACCOUNT_3=
